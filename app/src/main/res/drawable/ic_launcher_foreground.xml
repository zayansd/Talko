<?xml version="1.0" encoding="utf-8"?>
<!--
  Talko launcher icon foreground — white chat bubble with a dot accent.
  Designed to sit inside the safe zone of an adaptive icon (108dp canvas,
  72dp safe zone). All paths are centred on a 108×108 viewport.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Main speech bubble body -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
          M54,22
          C36.3,22 22,34.5 22,50
          C22,58.2 25.9,65.5 32.2,70.6
          L30,86
          L45.5,77.2
          C48.2,77.7 51.1,78 54,78
          C71.7,78 86,65.5 86,50
          C86,34.5 71.7,22 54,22 Z" />

    <!-- Three dots inside the bubble (typing indicator style) -->
    <path
        android:fillColor="#4C4FDE"
        android:pathData="M44,50 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" />
    <path
        android:fillColor="#4C4FDE"
        android:pathData="M54,50 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" />
    <path
        android:fillColor="#4C4FDE"
        android:pathData="M64,50 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" />

    <!-- Small accent dot (top-right corner of bubble) -->
    <path
        android:fillColor="#FFFFFF"
        android:alpha="0.7"
        android:pathData="M80,28 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0" />

</vector>
